{
    "name": "marekskopal/twelvedata",
    "type": "library",
    "description": "TwelveData API client library",
    "homepage": "https://www.fingather.com",
    "license": "MIT",
    "keywords": [
        "twelvedata",
        "twelve-data",
        "api",
        "finance",
        "stock",
        "market-data",
        "trading",
        "php-client"
    ],
    "authors": [
        {
            "name": "Marek Skopal",
            "homepage": "https://www.marekskopal.cz"
        }
    ],
    "require": {
        "php": ">=8.3",
        "php-http/discovery": "^1.19",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "php-http/guzzle7-adapter": "^1.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.3",
        "phrity/websocket": "^3.6",
        "shipmonk/phpstan-rules": "^4.3",
        "slevomat/coding-standard": "^8.14"
    },
    "suggest": {
        "nyholm/psr7": "PSR-7 message implementation",
        "phrity/websocket": "WebSocket client for real-time price streaming",
        "symfony/http-client": "HTTP client"
    },
    "support": {
        "issues": "https://github.com/marekskopal/twelvedata/issues",
        "source": "https://github.com/marekskopal/twelvedata"
    },
    "autoload": {
        "psr-4": {
            "MarekSkopal\\TwelveData\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MarekSkopal\\TwelveData\\Tests\\": [
                "tests/"
            ]
        }
    },
    "config": {
        "platform": {
            "php": "8.3"
        },
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
